{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.9.0" }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/" },
        {
            "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|ico|svg|json|txt)",
            "dest": "/public/$1.$2"
        },
        {
            "src": "/manifest.json",
            "dest": "/public/manifest.json",
            "headers": { "Content-Type": "application/json" }
        },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "public": true,
    "buildCommand": "vite build",
    "outputDirectory": "public",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://chatings-2lwd35ccp-wayoukzs-projects.vercel.app",
        "APP_KEY": "base64:aCDG1z2V1yOFa5KAAmoCKUNk4TdkFIoeu7KND7X8rlQ=",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "database",
        "DB_DATABASE": "pgsql",
        "DB_CONNECTION": "postgres",
        "DB_HOST": "@db.ziyhqisiqrnbanedlqqa.supabase.co",
        "DB_PORT": "6543",
        "DB_USERNAME": "postgres"
    }
